{erl_opts, [debug_info]}.

{deps, [
    %% Pinned to match hecate-daemon (the production daemon also pins
    %% `~> 4.4.10'). 4.4.10 added native CBOR encode/decode for
    %% integer map keys and negative integers — the exact wire shape
    %% the mpong state-broadcast payload uses. Pre-4.4.10 the harness
    %% crashes `macula_frame:wire_key/1' on integer-keyed maps, which
    %% makes the daemon-shape probes (pubsub_mpong_shape and
    %% sustained_mpong) unrunnable.
    {macula, "~> 4.4.10"}
]}.

{ct_opts, [
    {logdir, "_build/test/ct_logs"},
    {sys_config, "config/sys.config"}
]}.

{shell, [
    {apps, [macula_e2e]}
]}.

{dialyzer, [
    {plt_apps, all_deps},
    {warnings, [no_return]}
]}.
