{erl_opts, [debug_info]}.

{deps, [
    %% Pinned to match what macula-station runs in production. The
    %% harness uses the same SDK as the relay server side so any
    %% wire-format mismatch surfaces as a real-fleet bug, not a
    %% harness/server version skew. (hecate-daemon currently pins
    %% `~> 4.4.10' — also wire-compatible — so daemon-vs-harness
    %% behaviour should match. Confirmed: the mpong-payload publish
    %% path dies on both 4.4.10 and 4.7.x against the live fleet.)
    {macula, "~> 4.7.0"}
]}.

{ct_opts, [
    {logdir, "_build/test/ct_logs"},
    {sys_config, "config/sys.config"}
]}.

{shell, [
    {apps, [macula_e2e]}
]}.

{dialyzer, [
    {plt_apps, all_deps},
    {warnings, [no_return]}
]}.
